---
import Layout from "../layouts/Layout.astro";

const posts = Object.values(
  import.meta.glob("./posts/*.md", { eager: true })
);
---

<Layout pageTitle="Blog">
  <h1>Blog Archive</h1>

  <ul>
    {posts.map((post) => (
      <li>
        <a href={post.url}>{post.frontmatter.title}</a>
      </li>
    ))}
  </ul>
</Layout>