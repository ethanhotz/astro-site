---
import Layout from '../layouts/Layout.astro';

const pageTitle = "About Me";
const name = "Ethan";
const hometown = "Durango, Colorado";
const hobbies = ["music", "video games", "snowboarding", "working out"];
const student = true;
---

<Layout pageTitle={pageTitle}>
  <h1>{pageTitle}</h1>
  <h2>Hello, my name is {name}.</h2>
  <p>I’m from {hometown}.</p>
  <p>My hobbies are {hobbies.join(", ")}.</p>
  {student && <p>I am currently building my first Astro website.</p>}
</Layout>

<style>
  h1 {
    color: navy;
  }

  h2 {
    color: darkgreen;
  }
</style>